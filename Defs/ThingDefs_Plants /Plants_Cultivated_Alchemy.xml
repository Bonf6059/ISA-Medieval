<?xml version="1.0" encoding="utf-8" ?>
<Defs>
	
	<!--========== Flowers ==========-->
	
	<ThingDef ParentName="HealrootBase" Name="ISA_MindwortBase">
		<defName>ISA_Plant_Mindwort</defName>
		<label>mindwort</label>
		<graphicData>
			<texPath>Plants/FullGrown/MindwortPlant</texPath>
			<graphicClass>Graphic_Random</graphicClass>
		</graphicData>
		<description>A small, delicate herb with pale green leaves and tiny, yellow flowers, often used in crafting strong elixirs due to its potent properties.</description>
		<plant>
			<growDays>7</growDays>
			<sowWork>800</sowWork>
			<sowMinSkill>4</sowMinSkill>
			<sowTags>
				<li>Ground</li>
				<li>Hydroponic</li>
			</sowTags>
			<harvestedThingDef>ISA_Mindwort</harvestedThingDef>
			<purpose>Health</purpose>
			<fertilitySensitivity>0</fertilitySensitivity>
		</plant>
		<researchPrerequisites>
			<li>ISA_AlchemycalAgriculture</li>
		</researchPrerequisites>
	</ThingDef>

	<ThingDef ParentName="HealrootBase" Name="ISA_PoppyBase">
		<defName>ISA_Plant_Poppy</defName>
		<label>poppy</label>
		<graphicData>
			<texPath>Plants/FullGrown/PoppyPlant</texPath>
			<graphicClass>Graphic_Random</graphicClass>
		</graphicData>
		<description>A vibrant plant with striking red flowers, known for its use in various medicinal and alchemical preparations, often valued for its potent effects.</description>
		<plant>
			<growDays>7</growDays>
			<sowWork>800</sowWork>
			<sowMinSkill>4</sowMinSkill>
			<sowTags>
				<li>Ground</li>
				<li>Hydroponic</li>
			</sowTags>
			<harvestedThingDef>ISA_Poppy</harvestedThingDef>
			<purpose>Health</purpose>
		</plant>
		<researchPrerequisites>
			<li>ISA_AlchemycalAgriculture</li>
		</researchPrerequisites>
	</ThingDef>

	<ThingDef ParentName="HealrootBase" Name="ISA_FlyAgaricBase">
		<defName>ISA_Plant_FlyAgaric</defName>
		<label>fly agaric</label>
		<graphicData>
			<texPath>Plants/FullGrown/FlyAgaricPlant</texPath>
			<graphicClass>Graphic_Random</graphicClass>
		</graphicData>
		<description>A striking mushroom with a bright red cap adorned with white spots, known for its toxic properties. Despite its danger, it has been used in small doses in traditional remedies and rituals, though caution is always advised.</description>
		<plant>
			<growDays>7</growDays>
			<sowWork>800</sowWork>
			<sowMinSkill>6</sowMinSkill>
			<sowTags>
				<li>Ground</li>
				<li>Hydroponic</li>
			</sowTags>
			<harvestedThingDef>ISA_FlyAgaric</harvestedThingDef>
			<purpose>Health</purpose>
		</plant>
		<researchPrerequisites>
			<li>ISA_AlchemycalAgriculture</li>
		</researchPrerequisites>
	</ThingDef>

	<!-- Herbs -->
	
	<ThingDef ParentName="PlantBase">
		<defName>ISA_Plant_Herb</defName>
		<label>herb plant</label>
		<description>A fragrant, leafy green plant which has an iota of uses in alchemical concoctions, but which is only useful to feed animals if used on its own.</description>
		<descriptionHyperlinks>
			<ThingDef>ISA_RawHerb</ThingDef>
		</descriptionHyperlinks>
		<statBases>
			<MaxHitPoints>65</MaxHitPoints>
			<Nutrition>0.2</Nutrition>
		</statBases>
		<graphicData>
			<texPath>Plants/FullGrown/HerbPlant</texPath>
			<graphicClass>Graphic_Random</graphicClass>
		</graphicData>
		<selectable>true</selectable>
		<pathCost>10</pathCost>
		<ingestible/>
		<plant>
			<!--fertilityMin>0.70</fertilityMin
			<sowResearchPrerequisites>
				<li>DankPyon_IntermediateAgriculture</li>
			</sowResearchPrerequisites>	-->
			<fertilitySensitivity>0.50</fertilitySensitivity>
			<dieIfLeafless>true</dieIfLeafless>
			<harvestTag>Standard</harvestTag>
			<maxMeshCount>4</maxMeshCount>
			<harvestedThingDef>ISA_RawHerb</harvestedThingDef>
			<harvestYield>2</harvestYield>
			<harvestWork>200</harvestWork>
			<sowTags>
				<li>Ground</li>
				<li>Hydroponic</li>
			</sowTags>
			<topWindExposure>0.1</topWindExposure>
			<growDays>5.6</growDays>
			<visualSizeRange>0.2~0.4</visualSizeRange>
			<wildOrder>2</wildOrder>
			<purpose>Food</purpose>
		</plant>
	</ThingDef>

</Defs>
