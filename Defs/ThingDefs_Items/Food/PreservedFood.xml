<!--============== Preserved Fruit ===============-->
	
	<!-- Apple Jam -->
	<ThingDef ParentName="MealCooked" Name="ISA_JamBase">
		<defName>ISA_AppleJam</defName>
		<label>apple jam</label>
		<description>A sweet spread made by cooking fruits for a long time. Jam preserves the flavors of ripe fruit while often including pieces of fruit or pulp. It can be eaten on its own and doesn't rot so it's an easy way to store fruit for long periods of time.</description>
		<graphicData>
			<texPath>Items/Food/PreservedFood/Jam/AppleJam</texPath>
			<graphicClass>Graphic_StackCount</graphicClass>
		</graphicData>
		<statBases>
			<MarketValue>6</MarketValue>
			<Nutrition>0.12</Nutrition>
			<Flammability>0.5</Flammability>
			<Mass>0.1</Mass>
		</statBases>
		<tradeability>Sellable</tradeability>
		<!--	<comps>
			<li Class="CompProperties_Rottable">
				<daysToRotStart>60</daysToRotStart>
				<rotDestroys>true</rotDestroys>
			</li>
			<li Class="CompProperties_Ingredients">
			
			</li>
			
		</comps>	-->
		<ingestible>
			<preferability>MealSimple</preferability>
			<optimalityOffsetHumanlikes>16</optimalityOffsetHumanlikes>
			<optimalityOffsetFeedingAnimals>-8</optimalityOffsetFeedingAnimals>
		</ingestible>
	</ThingDef>
	
