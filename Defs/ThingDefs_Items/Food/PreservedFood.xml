<?xml version="1.0" encoding="utf-8" ?>
<Defs>

<!--============== Preserved Meat ===============-->

<!-- Dried Meats -->
	<ThingDef ParentName="OrganicProductBase">
		<defName>ISA_DriedMeat</defName>
		<label>dried Meat</label>
		<description>Dried meat to preserve and prolong shelf life for later use as an ingredient in meals.</description>
		<graphicData>
			<texPath>Items/Food/PreservedFood/DriedMeat</texPath>
			<graphicClass>Graphic_StackCount</graphicClass>
		</graphicData>
		<statBases>
			<MarketValue>1.9</MarketValue>
			<Nutrition>0.05</Nutrition>
		</statBases>
		<ingestible>
			<foodType>Meat</foodType>
			<preferability>DesperateOnlyForHumanlikes</preferability>
			<ingestEffect>EatMeat</ingestEffect>
			<ingestSound>RawMeat_Eat</ingestSound>
			<!--	<tasteThought>ISA_AteDriedMeat</tasteThought>	-->
			<optimalityOffsetHumanlikes>-5</optimalityOffsetHumanlikes>
			<optimalityOffsetFeedingAnimals>-10</optimalityOffsetFeedingAnimals>
		</ingestible>
		<thingCategories>
			<li>MeatRaw</li>
		</thingCategories>
		<comps>
			<li Class="CompProperties_Rottable">
				<daysToRotStart>60</daysToRotStart>
				<rotDestroys>true</rotDestroys>
			</li>
			<li Class="CompProperties_Ingredients">
				<splitTransferableFoodKind>true</splitTransferableFoodKind>
				<noIngredientsFoodKind>Meat</noIngredientsFoodKind>
			</li>
		</comps>
		<rotatable>false</rotatable>
		<tradeability>Sellable</tradeability>
	</ThingDef>

