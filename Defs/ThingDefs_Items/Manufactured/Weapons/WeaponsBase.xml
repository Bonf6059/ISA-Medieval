<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<!-- Grenades -->
	
	<ThingDef ParentName="BaseMakeableGrenade" Name="ISA_Medieval_MakeableGrenade" Abstract="True">
		<recipeMaker Inherit="false">
			<workSpeedStat>GeneralLaborSpeed</workSpeedStat>
			<workSkill>Crafting</workSkill>
			<effectWorking>Smith</effectWorking>
			<soundWorking>Recipe_Smith</soundWorking>
			<recipeUsers Inherit="False">
				<li MayRequire="OskarPotocki.VFE.Medieval2">VFEM2_AlchemicalWorkbench</li>
				<li>ISA_AlchemyTable</li>
			</recipeUsers>
		</recipeMaker>
		<tickerType>Normal</tickerType>
		<techLevel>Medieval</techLevel>
		<thingCategories>
			<li>Grenades</li>
		</thingCategories>
		<researchPrerequisites>
			<li>ISA_WarChemicals</li>
		</researchPrerequisites>	
	</ThingDef>

	<!-- ==================== Blunt Base ==================== -->

	<ThingDef Name="ISA_Base_Blunt_NormalSize" Abstract="True" ParentName="BaseMeleeWeapon_Blunt_Quality">
		<modExtensions>
			<li Class="VEF.Things.ThingDefExtension">
				<weaponDraftedDrawOffsets>
					<north>
						<drawOffset>(-0.15,0.0,0.10)</drawOffset> <!--0.30,0,0.40-->
						<angleOffset>100</angleOffset>
					</north>
					<east>
						<drawOffset>(0.10,0.00,0.10)</drawOffset> <!--0.30,0.2,0.40-->
						<angleOffset>-15</angleOffset>
					</east>
					<south>
						<drawOffset>(0.15,0.00,0.10)</drawOffset>
						<angleOffset>-15</angleOffset>
					</south>
					<west>
						<drawOffset>(-0.10,0.0,0.10)</drawOffset>
						<angleOffset>15</angleOffset>
					</west>
				</weaponDraftedDrawOffsets>
				<usableWithShields>true</usableWithShields>
			</li>
		</modExtensions>
		<equippedAngleOffset>-65</equippedAngleOffset>
		<uiIconScale>1.2</uiIconScale>
		<techLevel>Medieval</techLevel>
	</ThingDef>

	<!-- ==================== Two-Handed Blunt Base ==================== -->

