	<!--Waraxe -->
	<ThingDef ParentName="BaseMeleeWeapon_Sharp_Quality">
		<defName>ISA_MeleeWeapon_RoxWaraxe</defName>
		<label>rox waraxe</label>
		<description>A heavier version of the two-handed axe, the greataxe’s weight allows for high raw damage as well as solid durability. A great option for splitting shields or unarmored enemies. Requires great strength to wield effectively. \n\nFashioned with a piercing hammer made out of a rox’s horn, it allows for deadly armor penetrating attacks against heavily plated knights.</description>
		<graphicData>
			<texPath>Items/Weapons/Melee/Axes/RoxWaraxe</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<shaderType>CutoutComplex</shaderType>
			<drawSize>(1.25,1.25)</drawSize>
		</graphicData>
		<techLevel>Medieval</techLevel>
		<equippedAngleOffset>0</equippedAngleOffset>

		<statBases>
			<WorkToMake>21500</WorkToMake>
			<Mass>4</Mass>
		</statBases>

		<costStuffCount>160</costStuffCount>
		<stuffCategories>
			<li>Metallic</li>
		</stuffCategories>
		<costList>
			<ISA_RoxHorn>1</ISA_RoxHorn>
		</costList>

		<weaponTags>
			<li>ISA_RoxmontWaraxe</li>
		</weaponTags>

		<tools>
			<li>
				<label>shaft</label>
				<capacities>
				<li>Blunt</li>
				<li>Poke</li>
				</capacities>
				<power>13</power>
				<cooldownTime>2</cooldownTime>
			</li>
			<li><!-- slightly more damage than pike -->
				<label>Point</label>
				<capacities>
				<li>Stab</li>
				</capacities>
				<power>27.45</power>
				<cooldownTime>2.95</cooldownTime>
				<armorPenetration>0.3</armorPenetration>
			</li>
			<li><!-- same damage as greataxe -->
				<label>edge</label>
				<labelUsedInLogging>false</labelUsedInLogging>
				<capacities>
				<li>Cut</li>
				</capacities>
				<power>31</power>
				<cooldownTime>3.2</cooldownTime>
				<armorPenetration>0.4</armorPenetration>
			</li>
		</tools>
		<recipeMaker>
		<researchPrerequisite>LongBlades</researchPrerequisite>
