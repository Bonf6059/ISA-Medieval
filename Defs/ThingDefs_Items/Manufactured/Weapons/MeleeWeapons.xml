<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <ThingDef ParentName="BaseMeleeWeapon_Blunt">
    <defName>ISA_ShepherdCrook</defName>
    <label>shepherd's crook</label>
    <description>A shaped stick, with a hook at one end, for handling animals and bashing enemies to death. This weapon is so old that it is believed to be almost 20.000 years old.</description>
    <graphicData>
      <texPath>Items/Weapons/Melee/Misc/ISA_ShepherdCrook</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <uiIconScale>1.1</uiIconScale>
    <techLevel>Neolithic</techLevel>
    <weaponTags>
      <li>NeolithicMeleeBasic</li>
    </weaponTags>
    <weaponClasses>
      <li>Neolithic</li>
    </weaponClasses>
    <costStuffCount>40</costStuffCount>
    <statBases>
      <WorkToMake>1200</WorkToMake>
      <Mass>2</Mass>
    </statBases>
    <equippedStatOffsets>
		  <TameAnimalChance>0.05</TameAnimalChance> 
		  <TrainAnimalChance>0.10</TrainAnimalChance>
	  </equippedStatOffsets>
    <equippedAngleOffset>-65</equippedAngleOffset>
    <stuffCategories>
      <li>Metallic</li>
      <li>Woody</li>
      <li>Stony</li>
    </stuffCategories>
    <recipeMaker>
      <recipeUsers>
        <li>CraftingSpot</li>
      </recipeUsers>
      <displayPriority>300</displayPriority>
    </recipeMaker>
    <tools>
      <li>
        <label>handle</label>
        <capacities>
          <li>Poke</li>
        </capacities>
        <power>9</power>
        <cooldownTime>2</cooldownTime>
      </li>
      <li>
        <label>head</label>
        <labelUsedInLogging>false</labelUsedInLogging>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>14</power>
        <cooldownTime>2</cooldownTime>
      </li>
    </tools>
	<modExtensions MayRequire="Van.DATools">
		<li Class="ShowTools.ToolExtension">
			<workGiverDefs>
				<li>TakeRoamingAnimalsToPen</li>
				<li>TakeToPen</li>
				<li>Tame</li>
				<li>Train</li>
				<li>RebalanceAnimalsInPens</li>
			</workGiverDefs>
		</li>
	</modExtensions>
  </ThingDef>

