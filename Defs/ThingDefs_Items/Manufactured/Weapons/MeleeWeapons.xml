			<li>Metallic</li>
		</stuffCategories>
		<costList>
			<ISA_RoxHorn>1</ISA_RoxHorn>
		</costList>
		<weaponTags>
			<li>ISA_RoxmontWaraxe</li>
		</weaponTags>
		<tools>
			<li>
				<label>shaft</label>
				<capacities>
				<li>Blunt</li>
				<li>Poke</li>
				</capacities>
				<power>13</power>
				<cooldownTime>2</cooldownTime>
			</li>
			<li><!-- slightly more damage than pike -->
				<label>Point</label>
