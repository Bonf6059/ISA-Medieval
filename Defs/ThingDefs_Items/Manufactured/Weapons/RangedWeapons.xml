<?xml version="1.0" encoding="utf-8" ?>
<Defs>

<!-- Da cambiare proiettili; da creare ricerca "ISA_RangedWeapons" -->

  <!-- ============================== Crossbows ========================== -->
  <ThingDef ParentName="BaseWeaponNeolithic">
    <defName>ISA_Crossbow</defName>
    <label>crossbow</label>
    <description>A projectile launching weapon that, much like the bow, relies on a string pulled back for tension and propels a projectile upon release. However, the crossbow allows the wielder to maintain the draw thanks to the crossbow’s locking mechanism, thus making the ranged weapon both accessible to novices and powerful in combat.</description>
    <graphicData>
      <texPath>Items/Weapons/Ranged/Crossbow</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <soundInteract>Bow_Recurve</soundInteract>
    <costList>
      <WoodLog>50</WoodLog>
      <Steel>20</Steel>
    </costList>
    <statBases>
      <WorkToMake>14000</WorkToMake>
      <Mass>2.5</Mass>
      <AccuracyTouch>0.86</AccuracyTouch>
      <AccuracyShort>0.85</AccuracyShort>
      <AccuracyMedium>0.67</AccuracyMedium>
      <AccuracyLong>0.38</AccuracyLong>
      <RangedWeapon_Cooldown>2</RangedWeapon_Cooldown>
    </statBases>
    <equippedStatOffsets>
      <ShootingAccuracyPawn>2</ShootingAccuracyPawn>
    </equippedStatOffsets>
    <weaponTags>
      <li>ISA_Crossbow</li>
      <li>NeolithicRangedHeavy</li>
    </weaponTags>
    <weaponClasses>
      <li>Ranged</li>
      <li>RangedHeavy</li>
    </weaponClasses>
    <recipeMaker>
      <recipeUsers Inherit="False">
	    	<li>FueledSmithy</li>
	    	<li>ElectricSmithy</li>
      </recipeUsers>
      <researchPrerequisite>Greatbow</researchPrerequisite>
      <skillRequirements>
        <Crafting>6</Crafting>
      </skillRequirements>
    </recipeMaker>
    <verbs>
      <li>
        <verbClass>Verb_Shoot</verbClass>
        <hasStandardCommand>true</hasStandardCommand>
        <defaultProjectile>ISA_Arrow_Crossbow</defaultProjectile>
        <warmupTime>1.35</warmupTime>
        <range>25.9</range>
        <soundCast>Bow_Recurve</soundCast>
      </li>
    </verbs>
    <tools>
      <li>
        <label>limb</label>
        <capacities>
          <li>Blunt</li>
          <li>Poke</li>
        </capacities>
        <power>9</power>
        <cooldownTime>2</cooldownTime>
      </li>
    </tools>
  </ThingDef>
  <ThingDef ParentName="BaseProjectileNeolithic">
    <defName>ISA_Arrow_Crossbow</defName>
    <label>hunting bow arrow</label>
    <graphicData>
      <texPath>Things/Projectile/Arrow_Small</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <projectile>
      <damageDef>ArrowHighVelocity</damageDef>
      <damageAmountBase>16</damageAmountBase>
      <stoppingPower>1.2</stoppingPower>
      <speed>60</speed>
    </projectile>
  </ThingDef>

  <ThingDef ParentName="BaseWeaponNeolithic">
    <defName>ISA_WarBow</defName>
    <label>war bow</label>
    <description>A long bow carved from beautiful yew with tips steamed to provide slight bend and painted to keep the bow from shattering under stress—and the bow indeed experiences stress as the long body allows the hemp strand to pull further and with more tension. This helps arrows fly further and better penetrate surfaces, making the war bow a deadly weapon for combat.</description>
    <graphicData>
      <texPath>Items/Weapons/Ranged/BowWar</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(1.25,1.25)</drawSize>
    </graphicData>
    <!--comps>
      <li><compClass>CompOversizedWeapon.CompOversizedWeapon</compClass></li>
    </comps-->
    <soundInteract>Bow_Large</soundInteract>
    <costList>
      <WoodLog>70</WoodLog>
    </costList>
    <thingSetMakerTags><li>RewardStandardQualitySuper</li></thingSetMakerTags>
    <statBases>
      <WorkToMake>11500</WorkToMake>
      <Mass>3.5</Mass>
      <AccuracyTouch>0.6</AccuracyTouch>
      <AccuracyShort>0.89</AccuracyShort>
      <AccuracyMedium>0.79</AccuracyMedium>
      <AccuracyLong>0.6</AccuracyLong>
      <RangedWeapon_Cooldown>1.45</RangedWeapon_Cooldown>
    </statBases>
    <weaponTags>
      <li>ISA_Warbow</li>
      <li>NeolithicRangedHeavy</li>
    </weaponTags>
    <weaponClasses>
      <li>Ranged</li>
      <li>RangedHeavy</li>
    </weaponClasses>
    <verbs>
      <li>
        <verbClass>Verb_Shoot</verbClass>
        <hasStandardCommand>true</hasStandardCommand>
        <defaultProjectile>ISA_Arrow_War</defaultProjectile>
        <warmupTime>2.2</warmupTime>
        <range>31</range>
        <soundCast>Bow_Large</soundCast>
      </li>
    </verbs>
    <tools>
      <li>
        <label>limb</label>
        <capacities>
          <li>Blunt</li>
          <li>Poke</li>
        </capacities>
        <power>9</power>
        <cooldownTime>2</cooldownTime>
      </li>
    </tools>
    <recipeMaker>
      <recipeUsers>
        	<li>FueledSmithy</li>
	        <li>ElectricSmithy</li>
      </recipeUsers>
      <researchPrerequisite>Greatbow</researchPrerequisite>
      <skillRequirements>
        <Crafting>7</Crafting>
      </skillRequirements>
    </recipeMaker>
  </ThingDef>
  <ThingDef ParentName="BaseProjectileNeolithic">
    <defName>ISA_Arrow_War</defName>
    <label>war bow arrow</label>
    <graphicData>
      <texPath>Things/Projectile/Arrow_Small</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <projectile>
      <damageDef>Arrow</damageDef>
      <damageAmountBase>21</damageAmountBase>
      <stoppingPower>1.8</stoppingPower>
      <armorPenetrationBase>0.25</armorPenetrationBase>
      <speed>62</speed>
    </projectile>
  </ThingDef>

