<?xml version="1.0" encoding="utf-8" ?>
<Defs>

<!-- =============== Rathix =============== -->
	
	<ThingDef ParentName="MedicineBase">
		<defName>ISA_Rathix</defName>
		<label>rathix</label>
		<description>A potent concoction made from sangonite and flyagaric, it is believed that it grants the sturdiness of a rock troll to whoever ingests it. It's blood red colour and the strong smell is offputting to the majority of people. It carries a risk of addiction with prolonged use.</description>
		<possessionCount>10</possessionCount>
		<descriptionHyperlinks><HediffDef>ISA_High_Rathix</HediffDef></descriptionHyperlinks>
		<graphicData>
			<texPath>Items/Resources/Drugs/Rathix</texPath>
			<graphicClass>Graphic_StackCount</graphicClass>
		</graphicData>
		<socialPropernessMatters>false</socialPropernessMatters>
		<rotatable>false</rotatable>
		<statBases>
			<MarketValue>350</MarketValue> <!-- (Mixture Market value / cauldron drop ammount) + 20-->
			<Mass>0.5</Mass>
			<Flammability>0.1</Flammability>
		</statBases>
		<techLevel>Medieval</techLevel>
		<ingestible>
    		<foodType>Fluid</foodType>
			<nurseable>true</nurseable>
			<ingestHoldOffsetStanding>
				<northDefault>
					<offset>(0.18,0,0)</offset>
				</northDefault>
			</ingestHoldOffsetStanding>
			<ingestHoldUsesTable>false</ingestHoldUsesTable>
			<ingestCommandString>Drink {0}</ingestCommandString>
			<ingestReportString>Drinking {0}.</ingestReportString>
			<preferability>NeverForNutrition</preferability>
			<drugCategory>Medical</drugCategory>
			<outcomeDoers>
				<li Class="IngestionOutcomeDoer_GiveHediff">
				<hediffDef>ISA_High_Rathix</hediffDef>
				<severity>1.0</severity>
				</li>
			</outcomeDoers>
		</ingestible>
		
		<comps>
		<li Class="CompProperties_Drug">
			<listOrder>1000</listOrder>
			<overdoseSeverityOffset>0.08~0.14</overdoseSeverityOffset>
		</li>
		</comps>
	</ThingDef>
  
  <HediffDef>
    <defName>ISA_High_Rathix</defName>
    <hediffClass>Hediff_High</hediffClass>
    <label>rathix</label>
    <description>A temporary state of pain relief and increased fisical resistance.</description>
    <defaultLabelColor>(1,0,0.5)</defaultLabelColor>
    <scenarioCanAdd>true</scenarioCanAdd>
    <maxSeverity>1.0</maxSeverity>
    <isBad>false</isBad>
    <comps>
      <li Class="HediffCompProperties_SeverityPerDay">
        <severityPerDay>-1.5</severityPerDay>
        <showHoursToRecover>true</showHoursToRecover>
      </li>
    </comps>
      <stages>
        <li>
			<statFactors>
				<IncomingDamageFactor>0.5</IncomingDamageFactor>
			</statFactors>
			<painFactor>0.70</painFactor>
			<capMods>
          		<li>
           			<capacity>Moving</capacity>
           			<offset>-0.3</offset>
         		</li>
        	</capMods>
        </li>
		
      </stages>
  </HediffDef>

	<ThoughtDef>
		<defName>ISA_Thought_Rathix</defName>
		<workerClass>ThoughtWorker_Hediff</workerClass>
		<hediff>ISA_High_Rathix</hediff>
		<validWhileDespawned>true</validWhileDespawned>
		<developmentalStageFilter>Baby, Child, Adult</developmentalStageFilter>
		<stages>
		<li>
			<label>drank rathix</label>
			<description>Drinking this concoction makes me feel so stiff.</description>
			<baseMoodEffect>-2</baseMoodEffect>
		</li>
		</stages>
	</ThoughtDef>

<!-- =============== Silvarn =============== -->
	
	<ThingDef ParentName="MedicineBase">
		<defName>ISA_Silvarn</defName>
		<label>silvarn</label>
		<description>It is often used during hunts to see clearly even in adverse weather. It's especially common in nordern regions due to the common snowstorms.</description>
		<possessionCount>10</possessionCount>
		<descriptionHyperlinks><HediffDef>ISA_High_Silvarn</HediffDef></descriptionHyperlinks>
		<graphicData>
			<texPath>Items/Resources/Drugs/Silvarn</texPath>
			<graphicClass>Graphic_StackCount</graphicClass>
		</graphicData>
		<socialPropernessMatters>false</socialPropernessMatters>
		<rotatable>false</rotatable>
		<statBases>
			<MarketValue>350</MarketValue> <!-- (Mixture Market value / cauldron drop ammount) + 20-->
			<Mass>0.5</Mass>
			<Flammability>0.1</Flammability>
		</statBases>
		<techLevel>Medieval</techLevel>
		<ingestible>
    		<foodType>Processed</foodType>
			<nurseable>true</nurseable>
			<ingestHoldOffsetStanding>
				<northDefault>
					<offset>(0.21,0,0.05)</offset>
				</northDefault>
			</ingestHoldOffsetStanding>
			<ingestHoldUsesTable>false</ingestHoldUsesTable>
			<ingestCommandString>Snort {0}</ingestCommandString>
			<ingestReportString>Snorting {0}.</ingestReportString>
			<preferability>NeverForNutrition</preferability>
			<drugCategory>Medical</drugCategory>
			<outcomeDoers>
				<li Class="IngestionOutcomeDoer_GiveHediff">
				<hediffDef>ISA_High_Silvarn</hediffDef>
				<severity>1.0</severity>
				</li>
			</outcomeDoers>
		</ingestible>
		
		<comps>
		<li Class="CompProperties_Drug">
			<listOrder>1000</listOrder>
			<overdoseSeverityOffset>0.08~0.14</overdoseSeverityOffset>
		</li>
		</comps>
	</ThingDef>
  
  <HediffDef>
    <defName>ISA_High_Silvarn</defName>
    <hediffClass>Hediff_High</hediffClass>
    <label>silvarn</label>
    <description>A temporary state of increased sight and sharpness of mind.</description>
    <defaultLabelColor>(1,0,0.5)</defaultLabelColor>
    <scenarioCanAdd>true</scenarioCanAdd>
    <maxSeverity>1.0</maxSeverity>
    <isBad>false</isBad>
    <comps>
      <li Class="HediffCompProperties_SeverityPerDay">
        <severityPerDay>-1.5</severityPerDay>
        <showHoursToRecover>true</showHoursToRecover>
      </li>
    </comps>
      <stages>
        <li>
			<statFactors>
				<HuntingStealth>1.10</HuntingStealth>
				<ShootingAccuracyFactor_Long>1.05</ShootingAccuracyFactor_Long>
    			<ShootingAccuracyFactor_Medium>1.10</ShootingAccuracyFactor_Medium>
    			<ShootingAccuracyFactor_Short>1.15</ShootingAccuracyFactor_Short>
			</statFactors>
			<capMods>
				<li>
					<capacity>Consciousness</capacity>
					<offset>0.10</offset>
				</li>
        	</capMods>
        </li>
		
      </stages>
  </HediffDef>

	<ThoughtDef>
		<defName>ISA_Thought_Silvarn</defName>
		<workerClass>ThoughtWorker_Hediff</workerClass>
		<hediff>ISA_High_Silvarn</hediff>
		<validWhileDespawned>true</validWhileDespawned>
		<developmentalStageFilter>Baby, Child, Adult</developmentalStageFilter>
		<stages>
		<li>
			<label>snorted silvarn</label>
			<description>I never tought that I would be able to see this clearly.</description>
			<baseMoodEffect>2</baseMoodEffect>
		</li>
		</stages>
	</ThoughtDef>

