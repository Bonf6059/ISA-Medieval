	<ThingDef ParentName="ISA_ArmorHelmetMakeableBase">
		<defName>ISA_Headgear_ChainNasalHelmet</defName>
		<label>chain nasal helm</label>
		<description>A chainmail coif coupled with a simple round nasal helmet, offering excellent protection of the head.</description>
		<graphicData>
			<texPath>Pawn/HumanLike/Apparel/Headgear/ChainNasal/ChainNasal</texPath>
