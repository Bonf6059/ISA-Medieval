	<ThingDef ParentName="ISA_ArmorHelmetMakeableBase" Name="ISA_SalletBase">
		<defName>ISA_Headgear_SalletHelmet</defName>
		<label>sallet (visored)</label>
		<description>A sleek three-part helmet consisting of a top, visor, and bevor to protect the head, face, respectively. Lightweight, and very protective, though it hinders eyesight significantly.</description>
		<graphicData>
			<texPath>Pawn/HumanLike/Apparel/Headgear/SalletVisored/SalletVisored</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<recipeMaker>
			<skillRequirements>
				<Crafting>8</Crafting>
			</skillRequirements>
			<researchPrerequisite>PlateArmor</researchPrerequisite>
		</recipeMaker>
		<statBases>
			<WorkToMake>20000</WorkToMake>
			<MaxHitPoints>250</MaxHitPoints>
			<Mass>3.5</Mass>
			<StuffEffectMultiplierArmor>0.65</StuffEffectMultiplierArmor>
			<StuffEffectMultiplierInsulation_Cold>0.15</StuffEffectMultiplierInsulation_Cold>
			<StuffEffectMultiplierInsulation_Heat>0</StuffEffectMultiplierInsulation_Heat>
			<EquipDelay>10</EquipDelay>
		</statBases>
		<equippedStatOffsets>
			<ShootingAccuracyPawn>-3</ShootingAccuracyPawn>
			<PainShockThreshold>0.10</PainShockThreshold>
			<SocialImpact>0.15</SocialImpact>
		</equippedStatOffsets>
		<costStuffCount>80</costStuffCount>
		<apparel>
			<bodyPartGroups>
				<li>FullHead</li>
			</bodyPartGroups>
			<wornGraphicPath>Pawn/HumanLike/Apparel/Headgear/SalletVisored/SalletVisored</wornGraphicPath>
			<!--<tags>
				<li>DankPyon_KnightHelmet</li>
				<li>DankPyon_HedgeKnightHelmet</li>
			</tags>-->
			<layers>
				<li>Overhead</li>
			</layers>
		</apparel>
	</ThingDef>

