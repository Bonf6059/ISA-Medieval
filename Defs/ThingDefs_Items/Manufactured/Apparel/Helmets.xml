	<ThingDef ParentName="ISA_HeraldicGreatHelm">
		<defName>ISA_Headgear_HeraldicGreatHelmRoxmont</defName>
		<label>heraldic great helm (roxmont)</label>
		<description>A greatly ornamented full-plate great helmet, often worn by jousters and heraldic champions and notable figures of notable houses in war. Portrays one’s noble status while still offering considerable protection in battle. \n\nWorn by the noble knights and champions of the Roxmont house. Specially fitted with rox fur to provide resistance against the harsh winters of the north.</description>
		<graphicData>
			<texPath>Pawn/HumanLike/Apparel/Headgear/HeraldicHelmRoxmont/HeraldicHelmRoxmont</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<shaderType>CutoutComplex</shaderType>
		</graphicData>

		<costList>
			<ISA_Leather_Rox>30</ISA_Leather_Rox>
			<ISA_RoxHorn>2</ISA_RoxHorn>
		</costList>

		<recipeMaker>
			<recipeUsers>
				<li>ElectricSmithy</li>
				<li>FueledSmithy</li>
			</recipeUsers>
			<skillRequirements>
				<Crafting>8</Crafting>
			</skillRequirements>
			<researchPrerequisite>PlateArmor</researchPrerequisite>
		</recipeMaker>

		<apparel>
			<wornGraphicPath>Pawn/HumanLike/Apparel/Headgear/HeraldicHelmRoxmont/HeraldicHelmRoxmont</wornGraphicPath>
			<useWornGraphicMask>true</useWornGraphicMask>
			<tags Inherit="False">
				<li>ISA_HeraldicHelmRoxmont</li>
			</tags>
		</apparel>
	</ThingDef>

