<?xml version="1.0" encoding="utf-8"?>
<Defs>

	<ThingDef ParentName="ISA_ArmorHelmetMakeableBase" Name="ISA_HeraldicGreatHelm">
		<defName>ISA_Headgear_HeraldicGreatHelmAmboise</defName>
		<label>heraldic great helm (Amboise)</label>
		<description>A greatly ornamented full-plate great helmet, often worn by jousters and heraldic champions and notable figures of notable houses in war. Portrays one’s noble status while still offering considerable protection in battle. \n\nThis great helm carries the colours of house Amboise.</description>
		<graphicData>
			<texPath>Pawn/HumanLike/Apparel/Headgear/HeraldicHelmAmboise/HeraldicHelmAmboise</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<shaderType>CutoutComplex</shaderType>
		</graphicData>
		<recipeMaker Inherit="False"/>
		<statBases>
			<WorkToMake>20000</WorkToMake>
			<MaxHitPoints>250</MaxHitPoints>
			<Mass>3.5</Mass>
			<StuffEffectMultiplierArmor>0.65</StuffEffectMultiplierArmor>
			<StuffEffectMultiplierInsulation_Cold>0.15</StuffEffectMultiplierInsulation_Cold>
			<StuffEffectMultiplierInsulation_Heat>0</StuffEffectMultiplierInsulation_Heat>
			<EquipDelay>10</EquipDelay>
		</statBases>
		<equippedStatOffsets>
			<ShootingAccuracyPawn>-3</ShootingAccuracyPawn>
			<PainShockThreshold>0.10</PainShockThreshold>
			<SocialImpact>0.1</SocialImpact>
		</equippedStatOffsets>
		<costStuffCount>80</costStuffCount>
		<apparel>
			<bodyPartGroups>
				<li>FullHead</li>
			</bodyPartGroups>
			<wornGraphicPath>Pawn/HumanLike/Apparel/Headgear/HeraldicHelmAmboise/HeraldicHelmAmboise</wornGraphicPath>
			<useWornGraphicMask>true</useWornGraphicMask>
			<tags Inherit="False">
				<li>ISA_HeraldicHelmAmboise</li>
			</tags>
			<layers>
				<li>Overhead</li>
			</layers>
		</apparel>
		<colorGenerator Class="ColorGenerator_StandardApparel"/>
	</ThingDef>

