			<skillRequirements>
				<Crafting>6</Crafting>
			</skillRequirements>
			<researchPrerequisite>PlateArmor</researchPrerequisite>
		</recipeMaker>
		<statBases>
			<WorkToMake>16000</WorkToMake>
			<MaxHitPoints>150</MaxHitPoints>
