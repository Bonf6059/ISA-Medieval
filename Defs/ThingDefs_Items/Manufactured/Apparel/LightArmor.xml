<?xml version="1.0" encoding="utf-8"?>
<Defs>

	<ThingDef ParentName="ApparelMakeableBase">
		<defName>DankPyon_Apparel_Padded_Surcoat</defName>
		<label>padded surcoat</label>
		<description>A cloth mantle vest, sewn similarly to a gambeson, with a thick wool filling. Provides additional padding when worn but fails to deflect spear thrusts that come under shields.</description>
		<graphicData>
			<texPath>Things/Pawn/Humanlike/Apparel/LightArmor/Padded_Coat</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<techLevel>Medieval</techLevel>
		<recipeMaker>
			<skillRequirements>
				<Crafting>4</Crafting>
			</skillRequirements>
			<researchPrerequisite>ComplexClothing</researchPrerequisite>
		</recipeMaker>
		<stuffCategories>
			<li>Fabric</li>
		</stuffCategories>
		<costStuffCount>70</costStuffCount>
		<thingCategories>
			<li>Apparel</li>
		</thingCategories>
		<statBases>
			<MaxHitPoints>150</MaxHitPoints>
			<WorkToMake>10000</WorkToMake>
			<Mass>4</Mass>
			<StuffEffectMultiplierArmor>0.3</StuffEffectMultiplierArmor>
			<StuffEffectMultiplierInsulation_Cold>0.5</StuffEffectMultiplierInsulation_Cold>
			<StuffEffectMultiplierInsulation_Heat>0.15</StuffEffectMultiplierInsulation_Heat>
			<EquipDelay>3</EquipDelay>
		</statBases>
		<apparel>
			<bodyPartGroups>
				<li>Neck</li>
				<li>Shoulders</li>
				<li>Torso</li>
			</bodyPartGroups>
			<wornGraphicPath>Things/Pawn/Humanlike/Apparel/LightArmor/Padded_Coat</wornGraphicPath>
			<tags>
				<li>DankPyon_Peasant</li>
				<li>DankPyon_BrigandThug</li>
				<li>DankPyon_Mercenary</li>
				<li>DankPyon_MercenaryHeavy</li>
				<li>DankPyon_Archer</li>
				<li>DankPyon_Footman</li>
				<li>DankPyon_Billman</li>
				<li>DankPyon_Knight</li>
				<li>DankPyon_HedgeKnight</li>
				<li>MedievalMilitaryBasic</li>
			</tags>
			<layers>
				<li>OnSkin</li>
			</layers>
			<defaultOutfitTags>
				<li>Worker</li>
				<li>Soldier</li>
			</defaultOutfitTags>
			<canBeDesiredForIdeo>false</canBeDesiredForIdeo>
		</apparel>
