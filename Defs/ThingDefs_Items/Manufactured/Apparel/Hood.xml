<?xml version="1.0" encoding="utf-8" ?>
<Defs>

<!-- Wolf Hood -->

  <ThingDef ParentName="HatMakeableBase" Name="ISA_AnimalHood">
    <defName>ISA_WolfHood</defName>
    <label>wolf hood</label>
    <description>This impressive looking hood is traditionally worn by tribal chiefs to impress outsiders.
Gives small boosts in social interactions.</description>
    <techLevel>Neolithic</techLevel>
    <graphicData>
      <texPath>Pawn/HumanLike/Apparel/Headgear/Wolf/ArcticWolfHood</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
	<costStuffCount>25</costStuffCount>
	<stuffCategories>
		<li>Leathery</li>
	</stuffCategories>
    <recipeMaker>
      <recipeUsers>
        <li>ElectricTailoringBench</li>
        <li>HandTailoringBench</li>
        <li>CraftingSpot</li>
      </recipeUsers>
      <skillRequirements>
        <Crafting>4</Crafting>
      </skillRequirements>
      <factionPrerequisiteTags>
        <li>Tribal</li>
      </factionPrerequisiteTags>	  
    </recipeMaker>
    <statBases>
      <WorkToMake>2500</WorkToMake>
      <MaxHitPoints>80</MaxHitPoints>		  
      <Mass>1.2</Mass>
	  <StuffEffectMultiplierArmor>0.2</StuffEffectMultiplierArmor>
	  <StuffEffectMultiplierInsulation_Cold>0.5</StuffEffectMultiplierInsulation_Cold>
	  <StuffEffectMultiplierInsulation_Heat>0</StuffEffectMultiplierInsulation_Heat>
	  <EquipDelay>1.2</EquipDelay>
    </statBases>
    <equippedStatOffsets>
	  	<SocialImpact>0.1</SocialImpact>
		<HuntingStealth>-0.05</HuntingStealth>
    </equippedStatOffsets>
    <generateCommonality>0.1</generateCommonality>
    <apparel>
      <bodyPartGroups>
	      <li>FullHead</li>
      </bodyPartGroups>
	  <developmentalStageFilter>Child, Adult</developmentalStageFilter>
      <wornGraphicPath>Pawn/HumanLike/Apparel/Headgear/Wolf/ArcticWolfHood</wornGraphicPath>
      <layers>
        <li>Overhead</li>
      </layers>
      <tags>
        <li>Tribal</li>
      </tags>
      <defaultOutfitTags>
        <li>Soldier</li>
      </defaultOutfitTags>
      </apparel>
		  <tradeTags>
		      <li>BasicClothing</li>
		  </tradeTags>
  </ThingDef>

<!-- Deer Hood -->

  <ThingDef ParentName="ISA_AnimalHood">
    <defName>ISA_DeerHood</defName>
    <label>deer hood</label>
    <description>This hood is traditionally worn by hunters in a tribe to confuse prey.
This hood is made from leather and carved animal bones to resemble a deer.</description>
    <techLevel>Neolithic</techLevel>
    <graphicData>
      <texPath>Pawn/HumanLike/Apparel/Headgear/Deer/DeerHood</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <statBases>
      <WorkToMake>2500</WorkToMake>
      <MaxHitPoints>80</MaxHitPoints>		  
      <Mass>1.2</Mass>
	  <StuffEffectMultiplierArmor>0.2</StuffEffectMultiplierArmor>
	  <StuffEffectMultiplierInsulation_Cold>0.5</StuffEffectMultiplierInsulation_Cold>
	  <StuffEffectMultiplierInsulation_Heat>0</StuffEffectMultiplierInsulation_Heat>
	  <EquipDelay>1.2</EquipDelay>
    </statBases>
	<equippedStatOffsets>
		<HuntingStealth>0.1</HuntingStealth>
    </equippedStatOffsets>
    <generateCommonality>0.1</generateCommonality>
    <apparel>
      <countsAsClothingForNudity>false</countsAsClothingForNudity>
      <developmentalStageFilter>Child, Adult</developmentalStageFilter>
      <bodyPartGroups>
	<li>FullHead</li>
      </bodyPartGroups>
      <wornGraphicPath>Pawn/HumanLike/Apparel/Headgear/Deer/DeerHood</wornGraphicPath>
      <layers>
        <li>Overhead</li>
      </layers>
      <tags>
        <li>Tribal</li>
      </tags>
      <defaultOutfitTags>
        <li>Soldier</li>
      </defaultOutfitTags>
    </apparel>
		<tradeTags>
		      <li>BasicClothing</li>
		</tradeTags>
  </ThingDef>

<!-- Cultist Hood -->

	<ThingDef ParentName="ISA_HatMakeableBase">
		<defName>ISA_Headgear_CultistHood</defName>
		<label>Cultist Hood</label>
		<description>A thick, padded hood favored by cultists, offering insulation and minor blunt protection. Its sturdy design provides decent head protection on its own.</description>
		<graphicData>
			<texPath>Pawn/HumanLike/Apparel/Headgear/CultistHood/CultistHood</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<generateCommonality>0.50</generateCommonality>
		<costStuffCount>25</costStuffCount>
		<stuffCategories>
			<li>Leathery</li>
			<li>Fabric</li>
		</stuffCategories>
		<statBases>
			<WorkToMake>2200</WorkToMake>
			<Mass>0.15</Mass>
			<StuffEffectMultiplierArmor>0.25</StuffEffectMultiplierArmor>
			<StuffEffectMultiplierInsulation_Cold>0.5</StuffEffectMultiplierInsulation_Cold>
			<StuffEffectMultiplierInsulation_Heat>0.0</StuffEffectMultiplierInsulation_Heat>
			<EquipDelay>0.8</EquipDelay>
		</statBases>
		<equippedStatOffsets>
			<SocialImpact>-0.15</SocialImpact>
		</equippedStatOffsets>
		<apparel>
			<wornGraphicPath>Pawn/HumanLike/Apparel/Headgear/CultistHood/CultistHood</wornGraphicPath>
			<tags>
				<li>Tribal</li>
			</tags>
			<defaultOutfitTags>
				<li>Worker</li>
				<li>Soldier</li>
			</defaultOutfitTags>
			<layers>
				<li>Overhead</li>
			</layers>
			<developmentalStageFilter>Child, Adult</developmentalStageFilter>
		</apparel>
	</ThingDef>
	
</Defs>
