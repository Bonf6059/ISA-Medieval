<!-- Herbal extract -->
	
	<RecipeDef ParentName="ISA_Make_DrugAlchemy">
		<defName>ISA_Make_HerbalExtract</defName>
		<label>make herbal extract</label>
		<description>Make herbal extract.</description>
		<jobString>Making herbal extract.</jobString>
		<workAmount>600</workAmount>
		<ingredients>
			<li>
				<filter>
					<thingDefs>
						<li>MedicineHerbal</li>
						<li>ISA_Mindwort</li>
						<li>ISA_FlyAgaric</li>
						<li>ISA_Poppy</li>
					</thingDefs>
				</filter>
				<count>3</count>
			</li>
		</ingredients>
		<fixedIngredientFilter>
			<thingDefs>
				<li>MedicineHerbal</li>
				<li>ISA_Mindwort</li>
				<li>ISA_FlyAgaric</li>
				<li>ISA_Poppy</li>
