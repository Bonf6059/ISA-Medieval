			<thingDefs>
				<li>MedicineHerbal</li>
				<li>ISA_Mindwort</li>
				<li>ISA_FlyAgaric</li>
				<li>ISA_Poppy</li>
			</thingDefs>
		</defaultIngredientFilter>
		<products>
			<ISA_HerbalExtract>1</ISA_HerbalExtract>
		</products>
	</RecipeDef>

