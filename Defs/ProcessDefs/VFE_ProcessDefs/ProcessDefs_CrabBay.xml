<?xml version="1.0" encoding="UTF-8"?>
<Defs>

<!-- CrabMeat -->
  
    <PipeSystem.ProcessDef>
        <defName>ISA_KibbleToCrabMeat</defName>
        <label>Farming crabs for meat</label>
        <description>Feed kibble to mini leviathan crabs to produce leviathan stripes.</description>
        <spawnOnInteractionCell>true</spawnOnInteractionCell>
        <labelOverride>Feed kibble to mini leviathan crabs to produce leviathan stripes</labelOverride>
        <priorityInBillList>0</priorityInBillList>
        <descriptionHyperlinks>
            <ThingDef>DA_LeviathanStripes</ThingDef>
            <ThingDef>DA_LeviathanCrab</ThingDef>
            <ThingDef>Kibble</ThingDef>
        </descriptionHyperlinks>
        <ingredients>
            <li>
                <thing>Kibble</thing>
                <countNeeded>10</countNeeded>
            </li>
        </ingredients>
        <ticks>1200000</ticks>  <!-- a day is 60,000 ticks -->
        <results>
            <li>
                <thing>DA_LeviathanStripes</thing>
                <count>10</count>
            </li>
        </results>
        <useIngredients>true</useIngredients>
        <autoExtract>false</autoExtract>
        <effecterWhenWorking>false</effecterWhenWorking>  <!-- Utile per aggiungere effetti come il fumo usato nel Oven di StonebornCuisine -->
        <sustainerWhenWorking>false</sustainerWhenWorking>  <!-- Utile per aggiungere suoni come usato nel Oven di StonebornCuisine -->
    </PipeSystem.ProcessDef>

