<?xml version="1.0" encoding="UTF-8"?>
<Defs>

<!-- Paregoric -->
  
    <PipeSystem.ProcessDef>
        <defName>ISA_DistilParegoric</defName>
        <label>Distilling paregoric</label>
        <description>Distil paregoric from raw ingredients.</description>
        <spawnOnInteractionCell>true</spawnOnInteractionCell>
        <labelOverride>Distil paregoric from raw ingredients</labelOverride>
        <priorityInBillList>0</priorityInBillList>
        <descriptionHyperlinks>
            <ThingDef>ISA_Paregoric</ThingDef>
        </descriptionHyperlinks>
        <ingredients>
            <li>
                <thing>ISA_Mindwort</thing>
                <countNeeded>15</countNeeded>
            </li>
            <li>
                <thing>ISA_Opium</thing>
                <countNeeded>5</countNeeded>
            </li>
            <li>
                <thing>ISA_RawHerb</thing>
                <countNeeded>25</countNeeded>
            </li>
        </ingredients>
        <ticks>120000</ticks>  <!-- a day is 60,000 ticks -->
        <results>
            <li>
                <thing>ISA_Paregoric</thing>
                <count>10</count>
            </li>
        </results>
        <useIngredients>true</useIngredients>
        <autoExtract>false</autoExtract>
        <effecterWhenWorking>false</effecterWhenWorking>  <!-- Utile per aggiungere effetti come il fumo usato nel Oven di StonebornCuisine -->
        <sustainerWhenWorking>false</sustainerWhenWorking>  <!-- Utile per aggiungere suoni come usato nel Oven di StonebornCuisine -->
    </PipeSystem.ProcessDef>

