<?xml version="1.0" encoding="UTF-8"?>
<Defs>

<!-- Cheese -->
  
    <PipeSystem.ProcessDef>
        <defName>ISA_MilkIntoCheese</defName>
        <label>Pressing milk to make cheese</label>
        <description>Press milk to make cheese. <!-- The longer it rests the better quality it will be --> </description>
        <spawnOnInteractionCell>true</spawnOnInteractionCell>
        <labelOverride>Press milk to produce cheese</labelOverride>
        <priorityInBillList>0</priorityInBillList>
        <descriptionHyperlinks>
            <ThingDef>ISA_MealCheese</ThingDef>
            <ThingDef>Milk</ThingDef>
        </descriptionHyperlinks>
        <ingredients>
            <li>
                <thing>Milk</thing>
                <countNeeded>10</countNeeded>
            </li>
        </ingredients>
        <ticks>60000</ticks>  <!-- a day is 60,000 ticks -->
        <results>
            <li>
                <thing>ISA_MealCheese</thing>
                <count>5</count>
            </li>
        </results>
        <useIngredients>true</useIngredients>
        <autoExtract>false</autoExtract>
        <effecterWhenWorking>false</effecterWhenWorking>  <!-- Utile per aggiungere effetti come il fumo usato nel Oven di StonebornCuisine -->
        <sustainerWhenWorking>false</sustainerWhenWorking>  <!-- Utile per aggiungere suoni come usato nel Oven di StonebornCuisine -->
    </PipeSystem.ProcessDef>

