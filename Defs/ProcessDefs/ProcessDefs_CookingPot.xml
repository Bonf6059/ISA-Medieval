<?xml version="1.0" encoding="UTF-8"?>
<Defs>

	<!-- Stew Pot Base -->

  <ProcessorFramework.ProcessDef Name="ISA_CookingPotBase" Abstract="True">
		<processDays>2</processDays><!-- in days, a day is 60,000 ticks -->
		<capacityFactor>30.0</capacityFactor>
		<efficiency>10</efficiency>
		<usesTemperature>false</usesTemperature>
		<sunFactor>1.0~1.0</sunFactor>
		<rainFactor>1.0~1.0</rainFactor>
		<snowFactor>1.0~1.0</snowFactor>
		<windFactor>1.0~1.0</windFactor>
		<unpoweredFactor>0.0</unpoweredFactor>
		<unfueledFactor>0.0</unfueledFactor>
		<powerUseFactor>0.0</powerUseFactor>
		<fuelUseFactor>0.0</fuelUseFactor>
		<filledGraphicSuffix>Filled</filledGraphicSuffix>
		<usesQuality>False</usesQuality>
	<!--	<qualityDays>(0.25, 0.5, 1, 2, 3, 4, 5)</qualityDays>	-->
		<color>(255, 255, 255)</color><!-- 0-255 or 0.0-1.0 -->
		<customLabel/>
		<destroyChance>0.0</destroyChance>
	</ProcessorFramework.ProcessDef>

<!-- Processes -->

	<ProcessorFramework.ProcessDef ParentName="ISA_CookingPotBase">
		<defName>ISA_Stew</defName>
		<thingDef>ISA_CookedStew</thingDef>
		<ingredientFilter>
			<categories>
				<li>FoodRaw</li>
			</categories>
		</ingredientFilter>
	</ProcessorFramework.ProcessDef>

	<ProcessorFramework.ProcessDef ParentName="ISA_CookingPotBase">
		<defName>ISA_Soup</defName>
		<thingDef>ISA_CookedSoup</thingDef>
		<ingredientFilter>
			<categories>
				<li>PlantFoodRaw</li>
			</categories>
		</ingredientFilter>
	</ProcessorFramework.ProcessDef>

	<ProcessorFramework.ProcessDef ParentName="ISA_CookingPotBase" Name="ISA_CookingPotJamBase">
		<defName>ISA_AppleJamRecipe</defName>
		<thingDef>ISA_AppleJam</thingDef>
		<ingredientFilter>
			<thingDefs>
				<li>ISA_RawApples</li>
				<li>ISA_RawGrapes</li>
			</thingDefs>
		</ingredientFilter>
		<processDays>0.5</processDays><!-- in days, a day is 60,000 ticks -->
		<efficiency>0.3</efficiency>
		<capacityFactor>1.0</capacityFactor>
	</ProcessorFramework.ProcessDef>

	<ProcessorFramework.ProcessDef ParentName="ISA_CookingPotJamBase">
		<defName>ISA_BerryJamRecipe</defName>
		<thingDef>ISA_BerryJam</thingDef>
		<ingredientFilter>
			<thingDefs>
				<li>RawBerries</li>
			</thingDefs>
		</ingredientFilter>
	</ProcessorFramework.ProcessDef>

	<ProcessorFramework.ProcessDef ParentName="ISA_CookingPotJamBase">
		<defName>ISA_GrapeJamRecipe</defName>
		<thingDef>ISA_GrapeJam</thingDef>
		<ingredientFilter>
			<thingDefs>
				<li>ISA_RawGrapes</li>
			</thingDefs>
		</ingredientFilter>
	</ProcessorFramework.ProcessDef>
	
	
</Defs>
