		<thingDef>ISA_BerryJam</thingDef>
		<ingredientFilter>
			<thingDefs>
				<li>RawBerries</li>
			</thingDefs>
		</ingredientFilter>
	</ProcessorFramework.ProcessDef>

	<ProcessorFramework.ProcessDef ParentName="ISA_CookingPotJamBase">
		<defName>ISA_GrapeJamRecipe</defName>
		<thingDef>ISA_GrapeJam</thingDef>
		<ingredientFilter>
			<thingDefs>
				<li>ISA_RawGrapes</li>
			</thingDefs>
		</ingredientFilter>
	</ProcessorFramework.ProcessDef>
	
	
