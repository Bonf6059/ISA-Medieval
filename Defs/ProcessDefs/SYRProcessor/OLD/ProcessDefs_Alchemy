<?xml version="1.0" encoding="UTF-8"?>
<Defs>

		<!-- Brew kettle Base -->

 	<ProcessorFramework.ProcessDef Name="ISA_BrewKettleBase" Abstract="True">
		<processDays>2</processDays><!-- in days, a day is 60,000 ticks -->
		<capacityFactor>1.0</capacityFactor>
		<efficiency>2</efficiency>
		<usesTemperature>false</usesTemperature>
		<sunFactor>1.0~1.0</sunFactor>
		<rainFactor>1.0~1.0</rainFactor>
		<snowFactor>1.0~1.0</snowFactor>
		<windFactor>1.0~1.0</windFactor>
		<unpoweredFactor>0.0</unpoweredFactor>
		<unfueledFactor>0.0</unfueledFactor>
		<powerUseFactor>0.0</powerUseFactor>
		<fuelUseFactor>0.0</fuelUseFactor>
		<filledGraphicSuffix>Filled</filledGraphicSuffix>
		<usesQuality>False</usesQuality>
	<!--	<qualityDays>(0.25, 0.5, 1, 2, 3, 4, 5)</qualityDays>	-->
		<color>(255, 255, 255)</color><!-- 0-255 or 0.0-1.0 -->
		<customLabel/>
		<destroyChance>0.0</destroyChance>
	</ProcessorFramework.ProcessDef>
	
	<ProcessorFramework.ProcessDef ParentName="ISA_BrewKettleBase">
		<defName>ISA_MushInParegoric</defName>
		<thingDef>ISA_Paregoric</thingDef>
		<ingredientFilter>
			<thingDefs>
				<li>ISA_ParegoricMush</li>
			</thingDefs>
		</ingredientFilter>
		<efficiency>3</efficiency>	<!-- (efficiency) = amount of output for each unit of input -->
	</ProcessorFramework.ProcessDef>

	<ProcessorFramework.ProcessDef ParentName="ISA_BrewKettleBase">
		<defName>ISA_MushInRathix</defName>
		<thingDef>ISA_Rathix</thingDef>
		<ingredientFilter>
			<thingDefs>
				<li>ISA_RathixMush</li>
			</thingDefs>
		</ingredientFilter>
		<efficiency>2</efficiency>	<!-- (efficiency) = amount of output for each unit of input -->
	</ProcessorFramework.ProcessDef>
  
	<ProcessorFramework.ProcessDef ParentName="ISA_BrewKettleBase">
		<defName>ISA_MushInDravik</defName>
		<thingDef>ISA_Dravik</thingDef>
		<ingredientFilter>
			<thingDefs>
				<li>ISA_DravikMush</li>
			</thingDefs>
		</ingredientFilter>
		<efficiency>2</efficiency>	<!-- (efficiency) = amount of output for each unit of input -->
	</ProcessorFramework.ProcessDef>
		
</Defs>
