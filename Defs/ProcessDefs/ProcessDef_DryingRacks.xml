<?xml version="1.0" encoding="UTF-8"?>
<Defs>

	<!-- Dried Meat-->
	<ProcessorFramework.ProcessDef ParentName="ISA_DryingRackBase">
		<defName>ISA_DriedMeatProcess</defName>
		<thingDef>ISA_DriedMeat</thingDef>
		<ingredientFilter>
			<categories>
				<li>MeatRaw</li>
			</categories>
			<disallowedThingDefs>
				<li>ISA_DriedMeat</li>
				<li>ISA_DriedMeat_Human</li>
				<li>ISA_DriedMeat_Insect</li>
				<li>Meat_Human</li>
				<li>Meat_Megaspider</li>
			</disallowedThingDefs>
			<disallowedCategories>
				<li>Fish</li>
			</disallowedCategories>
		</ingredientFilter>
		<filledGraphicSuffix>FilledMeat</filledGraphicSuffix>
	</ProcessorFramework.ProcessDef>

	<!-- Dried Human Meat Process-->
	<ProcessorFramework.ProcessDef ParentName="ISA_DryingRackBase">
		<defName>ISA_DriedMeatHumanProcess</defName>
		<thingDef>ISA_DriedMeat_Human</thingDef>
		<ingredientFilter>
			<thingDefs>
				<li>Meat_Human</li>
			</thingDefs>
			<disallowedThingDefs>
				<li>ISA_DriedMeat_Human</li>
			</disallowedThingDefs>
		</ingredientFilter>
		<filledGraphicSuffix>FilledMeat</filledGraphicSuffix>
	</ProcessorFramework.ProcessDef>

	<!-- Dried Insect Meat Process-->
	<ProcessorFramework.ProcessDef ParentName="ISA_DryingRackBase">
		<defName>ISA_DriedMeatInsectProcess</defName>
		<thingDef>ISA_DriedMeat_Insect</thingDef>
		<ingredientFilter>
			<thingDefs>
				<li>Meat_Megaspider</li>
			</thingDefs>
		</ingredientFilter>
		<filledGraphicSuffix>FilledMeat</filledGraphicSuffix>
	</ProcessorFramework.ProcessDef>

	<!-- Dried herb Process-->
	<ProcessorFramework.ProcessDef ParentName="ISA_DryingRackBase">
		<defName>ISA_DriedHerbProcess</defName>
		<thingDef>Hay</thingDef>
		<ingredientFilter>
			<thingDefs>
				<li>ISA_RawHerb</li>
			</thingDefs>
		</ingredientFilter>
		<filledGraphicSuffix>FilledHay</filledGraphicSuffix>
	</ProcessorFramework.ProcessDef>
	
	<!-- ========== Alchemy ========== -->
	<!-- Alchemy -->

</Defs>
