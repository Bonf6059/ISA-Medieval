<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<ThingDef ParentName="BuildingBase">
		<defName>ISA_Well</defName>
		<label>well</label>
		<thingClass>Building</thingClass>
		<description>A small fortified hole dug through the ground to gain access to water.</description>
		<graphicData>
			<texPath>Building/Furnitures/Decorations/Well/Well</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<shaderType>CutoutComplex</shaderType>
			<drawSize>(3,3)</drawSize>
			<drawRotated>false</drawRotated>
		</graphicData>
		<uiIconScale>0.5</uiIconScale>
		<stuffCategories>
			<li>Stony</li>
		</stuffCategories>
		<costStuffCount>50</costStuffCount>
		<costList>
			<WoodLog>20</WoodLog>
		</costList>
		<altitudeLayer>Building</altitudeLayer>
		<fillPercent>0.5</fillPercent>
		<useHitPoints>True</useHitPoints>
		<statBases>
			<WorkToBuild>600</WorkToBuild>
			<MaxHitPoints>120</MaxHitPoints>
			<Flammability>1.0</Flammability>
		</statBases>
		<size>(1,1)</size>
		<passability>PassThroughOnly</passability>
		<pathCost>60</pathCost>
		<designationCategory>Furniture</designationCategory>
		<researchPrerequisites>
			<li>ComplexFurniture</li>
		</researchPrerequisites>
		<terrainAffordanceNeeded>Heavy</terrainAffordanceNeeded>
		<designatorDropdown>ISA_Hygiene</designatorDropdown>
	</ThingDef>

	<ThingDef ParentName="BuildingBase">
		<defName>ISA_Bucket</defName>
		<label>bucket</label>
		<thingClass>Building</thingClass>
		<description>A small wooden container used to transport or store liquids.</description>
		<graphicData>
			<texPath>Building/Furnitures/Decorations/Bucket/Bucket</texPath>
			<graphicClass>Graphic_Multi</graphicClass>
			<drawSize>(1,1)</drawSize>
		</graphicData>
		<stuffCategories>
			<li>Woody</li>
		</stuffCategories>
		<costStuffCount>20</costStuffCount>
		<altitudeLayer>Building</altitudeLayer>
		<fillPercent>0.2</fillPercent>
		<useHitPoints>True</useHitPoints>
		<statBases>
			<WorkToBuild>100</WorkToBuild>
			<MaxHitPoints>20</MaxHitPoints>
			<Flammability>1.0</Flammability>
		</statBases>
		<size>(1,1)</size>
		<passability>PassThroughOnly</passability>
		<pathCost>60</pathCost>
		<designationCategory>Furniture</designationCategory>
		<researchPrerequisites>
			<li>ComplexFurniture</li>
		</researchPrerequisites>
		<terrainAffordanceNeeded>Light</terrainAffordanceNeeded>
		<designatorDropdown>ISA_Hygiene</designatorDropdown>
	</ThingDef>

  <ThingDef ParentName="BuildingBase">
		<defName>ISA_Cesspit</defName>
		<label>cesspit</label>
		<thingClass>Building</thingClass>
		<description>A large fortified hole dug through the ground to dispose of human and animal wastes.</description>
		<graphicData>
			<texPath>Building/Furnitures/Decorations/Cesspit/Cesspit</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<shaderType>CutoutComplex</shaderType>
			<drawSize>(4,4)</drawSize>
		</graphicData>
		<stuffCategories>
			<li>Stony</li>
		</stuffCategories>
		<costStuffCount>100</costStuffCount>
		<altitudeLayer>Building</altitudeLayer>
		<fillPercent>0.5</fillPercent>
		<useHitPoints>True</useHitPoints>
		<statBases>
			<MaxHitPoints>200</MaxHitPoints>
			<WorkToBuild>1000</WorkToBuild>
			<Flammability>0.0</Flammability>
			<Beauty>-10</Beauty>
			<Cleanliness>-100</Cleanliness>
		</statBases>
		<size>(2,2)</size>
		<passability>Standable</passability>
		<pathCost>0</pathCost>
		<designationCategory>Furniture</designationCategory>
		<researchPrerequisites>
			<li>ComplexFurniture</li>
		</researchPrerequisites>
		<terrainAffordanceNeeded>Heavy</terrainAffordanceNeeded>
	  	<designatorDropdown>ISA_Hygiene</designatorDropdown>
	</ThingDef>

  <ThingDef ParentName="BuildingBase">
		<defName>ISA_WaterTower</defName>
		<label>water tower</label>
		<thingClass>Building</thingClass>
		<description>A tall building used to store massive amount of water. It is especcialy usefull to water crops and if a fire breaks out.</description>
		<graphicData>
			<texPath>Building/Furnitures/Decorations/WaterTower/WaterTower</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<shaderType>CutoutComplex</shaderType>
			<drawSize>(4,4)</drawSize>
		</graphicData>
		<stuffCategories>
			<li>Woody</li>
		</stuffCategories>
		<costStuffCount>50</costStuffCount>
    <costList>
			<Steel>10</Steel>
		</costList>
		<altitudeLayer>Building</altitudeLayer>
		<fillPercent>0.5</fillPercent>
		<useHitPoints>True</useHitPoints>
		<statBases>
			<MaxHitPoints>200</MaxHitPoints>
			<WorkToBuild>1000</WorkToBuild>
			<Flammability>0.5</Flammability>
			<Beauty>5</Beauty>
		</statBases>
    <uiIconScale>0.75</uiIconScale>
		<size>(2,2)</size>
		<passability>PassThroughOnly</passability>
		<pathCost>0</pathCost>
		<designationCategory>Furniture</designationCategory>
		<researchPrerequisites>
			<li>ComplexFurniture</li>
		</researchPrerequisites>
		<terrainAffordanceNeeded>Heavy</terrainAffordanceNeeded>
	  	<designatorDropdown>ISA_Hygiene</designatorDropdown>
	</ThingDef>
  
</Defs>
