<?xml version="1.0" encoding="utf-8" ?>
<Defs>

    <!-- Criopyrinth heart  -->

    <ThingDef ParentName="DV_GolemBodypart_Implant">
        <defName>ISA_Golem_CriopyrinthHeart</defName>
        <label>criopyrinth heart</label>
        <description>An heart made of criopyrinth shards locked between anima branches. Increases max comfortable temperature at the cost of making the golem more brittle.</description>
        <descriptionHyperlinks>
            <RecipeDef>ISA_Golem_InstallCriopyrinthHeart</RecipeDef>
        </descriptionHyperlinks>
        <statBases>
            <MarketValue>100</MarketValue>
            <Mass>1</Mass>
        </statBases>
        <costList>
            <DV_AnimaLog>40</DV_AnimaLog>
            <ISA_Criopyrinth>25</ISA_Criopyrinth>
        </costList>
        <recipeMaker>
            <researchPrerequisite>DV_GolemResearch_GolemancyModules</researchPrerequisite>
        </recipeMaker>
    </ThingDef>

    <HediffDef>
        <defName>ISA_Golem_InstalledCriopyrinthHeart</defName>
        <label>criopyrinth heart</label>
        <description>An heart made of criopyrinth shards locked between anima branches. Increases max comfortable temperature at the cost of making the golem more brittle.</description>
        <hediffClass>HediffWithComps</hediffClass>
        <defaultLabelColor>(171, 245, 216)</defaultLabelColor>
        <makesSickThought>false</makesSickThought>
        <tendable>false</tendable>
        <priceImpact>false</priceImpact>
        <isBad>False</isBad>
        <spawnThingOnRemoved>ISA_Golem_CriopyrinthHeart</spawnThingOnRemoved>
        <stages>
            <li>
		        	<statFactors>
				        <IncomingDamageFactor>1.1</IncomingDamageFactor>
			          <ComfyTemperatureMax>20</ComfyTemperatureMax>
              </statFactors>
            </li>
        </stages>
        <comps>
        </comps>
    </HediffDef>

    <RecipeDef ParentName="DV_GolemBodypart_Install">
        <defName>ISA_Golem_InstallCriopyrinthHeart</defName>
        <label>attach criopyrinth heart</label>
        <description>Attach a criopyrinth heart.</description>
        <descriptionHyperlinks>
            <ThingDef>ISA_Golem_CriopyrinthHeart</ThingDef>
        </descriptionHyperlinks>
        <jobString>Attaching criopyrinth heart.</jobString>
        <effectWorking>ClayTurning</effectWorking>
        <ingredients>
            <li>
                <filter>
                    <thingDefs>
                        <li>ISA_Golem_CriopyrinthHeart</li>
                    </thingDefs>
                </filter>
                <count>1</count>
            </li>
        </ingredients>
        <fixedIngredientFilter>
            <thingDefs>
                <li>ISA_Golem_CriopyrinthHeart</li>
            </thingDefs>
        </fixedIngredientFilter>
        <appliedOnFixedBodyParts>
            <li>DV_Golem_Torso</li>
        </appliedOnFixedBodyParts>
        <addsHediff>ISA_Golem_InstalledCriopyrinthHeart</addsHediff>
    </RecipeDef>


</Defs>
