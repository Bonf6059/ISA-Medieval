<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<!-- Castle Doors -->
	<ThingDef ParentName="DoorBase">
		<defName>ISA_2x1CastleDoor</defName>
		<label>castle door (medium)</label>
		<description>An incredibly resistant door made out of oversized stone blocks. Very slow to build. It’s a good choice if you want to keep the enemies out - or in. The door requires walls on either side to function.</description>
		<thingClass>Building_MultiTileDoor</thingClass>
		<statBases>
			<WorkToBuild>5500</WorkToBuild>
			<MaxHitPoints>800</MaxHitPoints>
			<DoorOpenSpeed>0.8</DoorOpenSpeed>
		</statBases>
		<graphicData>
			<texPath>Building/Structures/Gate/CastleDoor/CastleDoor2x1_Mover</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<damageData>
				<enabled>false</enabled>
			</damageData>
		</graphicData>
		<uiIconPath>Building/Structures/Gate/CastleDoor/CastleDoor2x1_MenuIcon_south</uiIconPath>
		<useBlueprintGraphicAsGhost>true</useBlueprintGraphicAsGhost>
		<size>(2, 1)</size>
		<rotatable>true</rotatable>
		<costStuffCount>130</costStuffCount>
		<stuffCategories Inherit="False">
			<li>Stony</li>
		</stuffCategories>
		<building>
			<blueprintClass>Blueprint_Build</blueprintClass>
			<blueprintGraphicData>
				<texPath>Building/Structures/Gate/CastleDoor/CastleDoor2x1_MenuIcon</texPath>
				<graphicClass>Graphic_Multi</graphicClass>
				<shaderType>EdgeDetect</shaderType>
				<drawSize>(2.6, 3.1)</drawSize>
			</blueprintGraphicData>
			<isSupportDoor>true</isSupportDoor>
			<doorTopGraphic>
				<texPath>Building/Structures/Gate/CastleDoor/CastleDoor2x1_Top</texPath>
				<graphicClass>Graphic_Multi</graphicClass>
				<drawSize>(3.1, 2.3)</drawSize>
			</doorTopGraphic>
			<doorSupportGraphic>
				<texPath>Building/Structures/Gate/CastleDoor/CastleDoor2x1_Support</texPath>
				<graphicClass>Graphic_Multi</graphicClass>
				<drawSize>(3.1, 2.3)</drawSize>
			</doorSupportGraphic>
  <!--<soundDoorOpenManual>VFEM2_CastleGate_OpenManual</soundDoorOpenManual>
			<soundDoorCloseManual>VFEM2_CastleGate_CloseManual</soundDoorCloseManual>  -->
		</building>
		<researchPrerequisites>
			<li>ISA_MedievalDefences</li>
		</researchPrerequisites>
		<placeWorkers>
			<li>PlaceWorker_MultiCellDoor</li>
		</placeWorkers>
	</ThingDef>
	
